---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import HiddenText from '../components/HiddenText.astro';
import NoteTimeline from '../components/NoteTimeline.astro';
import Toc from '../components/Toc.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	// 有配对翻译时传入对应 URL，页头语言切换会直接跳过去
	translationHref?: string;
	// 文末返回链接（写作栏目会传 /writing/）
	backHref?: string;
	backLabelZh?: string;
	backLabelEn?: string;
	// 笔记栏目专用：传了才渲染两侧栏（右侧文内目录 + 左侧时间轴）和小屏目录抽屉
	headings?: { depth: number; slug: string; text: string }[];
	timeline?: {
		id: string;
		base: string;
		href: string;
		title: string;
		lang: string;
		year: number;
		mmdd: string;
	}[];
	currentId?: string;
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	lang,
	tags,
	references = [],
	translationHref,
	backHref = '/',
	backLabelZh = '回到致云雀',
	backLabelEn = 'All notes',
	headings = [],
	timeline = [],
	currentId,
} = Astro.props;
const htmlLang = lang === 'zh' ? 'zh-CN' : 'en';

// 传了 headings/timeline 才出宽屏三栏（笔记和夜莺颂两个栏目都传）
const hasSides = timeline.length > 0 || headings.length > 0;

// string 项转成统一的对象形状
const refs = references.map((r) => (typeof r === 'string' ? { title: r } : r));
---

<html lang={htmlLang} data-page-lang={lang} data-translation-href={translationHref}>
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />
		<div class:list={['shell', { wide: hasSides }]}>
			{timeline.length > 0 && <NoteTimeline items={timeline} currentId={currentId} />}
			<main>
				<article>
				{
					heroImage && (
						<Image class="hero" width={1020} height={510} src={heroImage} alt="" />
					)
				}
				<header class="post-head">
					<p class="meta">
						<FormattedDate date={pubDate} />
						<span class:list={['lang-chip', lang]}>{lang === 'zh' ? '中文' : 'EN'}</span>
						{
							translationHref && (
								<a class="translation" href={translationHref}>
									{lang === 'zh' ? 'Read in English →' : '阅读中文版 →'}
								</a>
							)
						}
					</p>
					<h1>{title}</h1>
					{
						tags.length > 0 && (
							<p class="tags">
								{tags.map((tag, i) => (
									<span class:list={['chip', `c${i % 5}`]}>#{tag}</span>
								))}
							</p>
						)
					}
					{
						updatedDate && (
							<p class="updated">
								更新于 <FormattedDate date={updatedDate} />
							</p>
						)
					}
				</header>
				<div class="prose">
					<slot />
				</div>
				{
					refs.length > 0 && (
						<details class="refs" open>
							<summary>
								参考 References <span class="count">· {refs.length}</span>
							</summary>
							<ol>
								{refs.map((ref) => (
									<li>
										{ref.author && <span class="author">{ref.author}, </span>}
										{ref.url ? (
											<a href={ref.url} target="_blank" rel="noopener">
												{ref.title} ↗
											</a>
										) : (
											<span>{ref.title}</span>
										)}
									</li>
								))}
							</ol>
						</details>
					)
				}
				<p class="back">
					<a href={backHref}>
						← <span class="only-zh">{backLabelZh}</span><span class="only-en">{backLabelEn}</span>
					</a>
				</p>
				</article>
			</main>
			{headings.length > 0 && <Toc headings={headings} />}
		</div>
		<Footer />
		<HiddenText />
	</body>
</html>

<style>
	/* 三栏外壳：中间正文保持原宽度，宽屏时左侧放时间轴、右侧放文内目录，
	   窄屏自动回到单栏（两侧栏组件内部自带 display:none 断点） */
	.shell {
		flex: 1;
		width: 100%;
	}
	@media (min-width: 1160px) {
		.shell.wide {
			display: grid;
			grid-template-columns: minmax(0, 1fr) minmax(0, 44rem) minmax(0, 1fr);
			align-items: start;
		}
		.shell.wide > main {
			grid-column: 2;
		}
		.shell.wide > :global(.tl) {
			grid-column: 1;
			justify-self: end;
		}
		.shell.wide > :global(.toc) {
			grid-column: 3;
			justify-self: start;
		}
	}

	.hero {
		width: 100%;
		height: auto;
		border-radius: 14px;
		margin-bottom: 2rem;
	}
	.post-head {
		margin: 0.5rem 0 2.5rem;
	}
	.meta {
		font-family: var(--font-mono);
		font-size: 0.85rem;
		color: var(--tx-2);
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.6rem;
		margin: 0 0 0.9rem;
	}
	.translation {
		color: var(--sky);
		text-decoration: none;
		border-bottom: 1px solid color-mix(in srgb, var(--sky) 40%, transparent);
		transition: border-color 0.2s ease;
	}
	.translation:hover {
		border-bottom-color: var(--sky);
	}
	h1 {
		font-size: 2.1rem;
		line-height: 1.25;
		margin: 0;
		letter-spacing: -0.015em;
	}
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin: 1.1rem 0 0;
	}
	.updated {
		font-size: 0.85rem;
		color: var(--tx-2);
		font-style: italic;
		margin: 0.8rem 0 0;
	}

	/* 参考文献：可折叠，仅当 frontmatter 写了 references 才渲染 */
	.refs {
		margin-top: 3rem;
		border-top: 1px solid var(--line);
		padding-top: 1.1rem;
	}
	.refs summary {
		font-family: var(--font-mono);
		font-size: 0.85rem;
		color: var(--tx-2);
		cursor: pointer;
		user-select: none;
		list-style-position: outside;
		transition: color 0.2s ease;
	}
	.refs summary:hover {
		color: var(--sky);
	}
	.refs .count {
		color: var(--sky);
	}
	.refs ol {
		margin: 0.9rem 0 0;
		padding-left: 1.3rem;
		font-size: 0.88rem;
		line-height: 1.8;
		color: var(--tx-2);
	}
	.refs li {
		margin: 0.3rem 0;
		padding-left: 0.2rem;
	}
	.refs li::marker {
		font-family: var(--font-mono);
		font-size: 0.8rem;
		color: var(--sky);
	}
	.refs .author {
		color: var(--tx);
	}
	.refs a {
		color: var(--sky);
		text-decoration: none;
		border-bottom: 1px solid color-mix(in srgb, var(--sky) 40%, transparent);
		transition: border-color 0.2s ease;
	}
	.refs a:hover {
		border-bottom-color: var(--sky);
	}

	.back {
		margin-top: 3.5rem;
	}
	.back a {
		font-family: var(--font-mono);
		font-size: 0.9rem;
		color: var(--tx-2);
		text-decoration: none;
		border-bottom: 2px solid var(--line);
		transition:
			color 0.2s ease,
			border-color 0.2s ease;
	}
	.back a:hover {
		color: var(--sky);
		border-bottom-color: var(--sky);
	}
</style>
