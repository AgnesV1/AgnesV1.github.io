---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, lang, tags } = Astro.props;
const htmlLang = lang === 'zh' ? 'zh-CN' : 'en';
---

<html lang={htmlLang}>
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />
		<main>
			<article>
				{
					heroImage && (
						<Image class="hero" width={1020} height={510} src={heroImage} alt="" />
					)
				}
				<header class="post-head">
					<p class="meta">
						<FormattedDate date={pubDate} />
						<span class:list={['lang-chip', lang]}>{lang === 'zh' ? '中文' : 'EN'}</span>
					</p>
					<h1>{title}</h1>
					{
						tags.length > 0 && (
							<p class="tags">
								{tags.map((tag, i) => (
									<span class:list={['chip', `c${i % 5}`]}>#{tag}</span>
								))}
							</p>
						)
					}
					{
						updatedDate && (
							<p class="updated">
								更新于 <FormattedDate date={updatedDate} />
							</p>
						)
					}
				</header>
				<div class="prose">
					<slot />
				</div>
				<p class="back"><a href="/">← 回到全部文章</a></p>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		width: 100%;
		height: auto;
		border-radius: 14px;
		margin-bottom: 2rem;
	}
	.post-head {
		margin: 0.5rem 0 2.5rem;
	}
	.meta {
		font-family: var(--font-mono);
		font-size: 0.85rem;
		color: var(--tx-2);
		display: flex;
		align-items: center;
		gap: 0.6rem;
		margin: 0 0 0.9rem;
	}
	h1 {
		font-size: 2.1rem;
		line-height: 1.25;
		margin: 0;
		letter-spacing: -0.015em;
	}
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin: 1.1rem 0 0;
	}
	.updated {
		font-size: 0.85rem;
		color: var(--tx-2);
		font-style: italic;
		margin: 0.8rem 0 0;
	}
	.back {
		margin-top: 3.5rem;
	}
	.back a {
		font-family: var(--font-mono);
		font-size: 0.9rem;
		color: var(--tx-2);
		text-decoration: none;
		border-bottom: 2px solid var(--line);
		transition:
			color 0.2s ease,
			border-color 0.2s ease;
	}
	.back a:hover {
		color: var(--sky);
		border-bottom-color: var(--sky);
	}
</style>
