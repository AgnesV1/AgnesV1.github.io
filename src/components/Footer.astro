---
import { GITHUB_URL, SITE_TITLE, YOUTUBE_URL } from '../consts';

const today = new Date();
---

<footer>
	<div class="dots" aria-hidden="true">
		<span class="d1"></span><span class="d2"></span><span class="d3"></span><span class="d4"
		></span><span class="d5"></span>
	</div>
	<p>
		© {today.getFullYear()}&nbsp;{SITE_TITLE} · <a href="/rss.xml">RSS</a>
		{GITHUB_URL && <> · <a href={GITHUB_URL}>GitHub</a></>}
		{YOUTUBE_URL && <> · <a href={YOUTUBE_URL}>YouTube</a></>}
		 · Built with <a href="https://astro.build" target="_blank">Astro</a>
	</p>
	<p class="license">
		<span class="only-zh">
			本站文字作品采用
			<a href="https://creativecommons.org/licenses/by-nc-nd/4.0/deed.zh-hans" target="_blank" rel="license noopener">CC BY-NC-ND 4.0</a>
			许可 · 转载请注明出处
		</span>
		<span class="only-en">
			Text licensed under
			<a href="https://creativecommons.org/licenses/by-nc-nd/4.0/" target="_blank" rel="license noopener">CC BY-NC-ND 4.0</a>
			· Please attribute when sharing
		</span>
	</p>
</footer>

<script>
	import { SITE_TITLE } from '../consts';

	// 复制较长文本时，剪贴板自动附上来源与许可协议。
	// 选区碰到防剧透隐藏段时直接让位——HiddenText 的复制拦截会把那部分替换成 █。
	const MIN_LEN = 42;
	document.addEventListener('copy', (e) => {
		const t = e.target as HTMLElement;
		if (t && (t.tagName === 'TEXTAREA' || t.tagName === 'INPUT')) return;
		const sel = document.getSelection();
		if (!sel || sel.isCollapsed || sel.rangeCount === 0) return;
		const range = sel.getRangeAt(0);
		const anc = range.commonAncestorContainer;
		const el = anc.nodeType === 1 ? (anc as HTMLElement) : anc.parentElement;
		if (el?.closest?.('hidden-text') || range.cloneContents().querySelector('hidden-text')) return;
		const text = sel.toString();
		if (text.length < MIN_LEN) return;
		e.clipboardData?.setData(
			'text/plain',
			`${text}\n\n—— ${SITE_TITLE}\n${location.origin}${location.pathname} · CC BY-NC-ND 4.0`,
		);
		e.preventDefault();
	});
</script>

<style>
	footer {
		padding: 2.5rem 1.25rem 3.5rem;
		text-align: center;
		font-size: 0.85rem;
		color: var(--tx-2);
	}
	.dots {
		display: flex;
		justify-content: center;
		gap: 0.5rem;
		margin-bottom: 1rem;
	}
	.dots span {
		width: 7px;
		height: 7px;
		border-radius: 50%;
	}
	.d1 {
		background: var(--coral);
	}
	.d2 {
		background: var(--sun);
	}
	.d3 {
		background: var(--mint);
	}
	.d4 {
		background: var(--sky);
	}
	.d5 {
		background: var(--lav);
	}
	.license {
		margin-top: 0.4rem;
		font-size: 0.78rem;
		color: color-mix(in srgb, var(--tx-2) 75%, transparent);
	}
	a {
		color: var(--tx-2);
		text-decoration: none;
		border-bottom: 1px solid var(--line);
		transition:
			color 0.2s ease,
			border-color 0.2s ease;
	}
	a:hover {
		color: var(--coral);
		border-bottom-color: var(--coral);
	}
</style>
