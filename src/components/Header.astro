---
import { GITHUB_URL, INSTAGRAM_URL, PHOTOS_URL, SITE_TITLE, YOUTUBE_URL } from '../consts';
import HeaderLink from './HeaderLink.astro';
import LangToggle from './LangToggle.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header>
	<nav>
		<a class="logo" href="/">{SITE_TITLE}<span class="dot">.</span></a>
		<div class="links">
			<HeaderLink href="/">笔记 <span class="en-word">Notes</span></HeaderLink>
			<HeaderLink href="/writing">写作 <span class="en-word">Writing</span></HeaderLink>
			{
				PHOTOS_URL && (
					<a class="ext" href={PHOTOS_URL} target="_blank" rel="noopener">
						摄影 <span class="en-word">Photos</span> <span class="arrow">↗</span>
					</a>
				)
			}
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="icons">
			{
				YOUTUBE_URL && (
					<a href={YOUTUBE_URL} target="_blank" class="icon yt">
						<span class="sr-only">YouTube 频道</span>
						<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
							<path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.3 31.3 0 0 0 0 12c0 1.9.2 3.9.5 5.8a3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1c.3-1.9.5-3.9.5-5.8s-.2-3.9-.5-5.8ZM9.6 15.6V8.4L15.8 12l-6.2 3.6Z" />
						</svg>
					</a>
				)
			}
			{
				INSTAGRAM_URL && (
					<a href={INSTAGRAM_URL} target="_blank" class="icon ig">
						<span class="sr-only">Instagram</span>
						<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
							<rect x="2.5" y="2.5" width="19" height="19" rx="5.2" />
							<circle cx="12" cy="12" r="4.4" />
							<circle cx="17.6" cy="6.4" r="1.2" fill="currentColor" stroke="none" />
						</svg>
					</a>
				)
			}
			{
				GITHUB_URL && (
					<a href={GITHUB_URL} target="_blank" class="icon gh">
						<span class="sr-only">GitHub 主页</span>
						<svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" aria-hidden="true">
							<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
						</svg>
					</a>
				)
			}
			<a href="/rss.xml" class="icon rss">
				<span class="sr-only">RSS 订阅</span>
				<svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor" aria-hidden="true">
					<path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56Zm0 5.66v2.83a7.07 7.07 0 0 1 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9ZM6 16a2 2 0 1 0 0 4 2 2 0 0 0 0-4Z" />
				</svg>
			</a>
			<LangToggle />
			<ThemeToggle />
		</div>
	</nav>
</header>

<style>
	header {
		width: 100%;
	}
	nav {
		max-width: 44rem;
		margin-inline: auto;
		padding: 1.4rem 1.25rem;
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}
	.logo {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 1.3rem;
		letter-spacing: -0.02em;
		color: var(--tx);
		text-decoration: none;
	}
	.logo .dot {
		color: var(--coral);
	}
	.links {
		display: flex;
		align-items: baseline;
		gap: 1.1rem;
		margin-left: auto;
		white-space: nowrap;
	}
	.links .en-word {
		font-family: var(--font-mono);
		font-size: 0.8em;
		opacity: 0.75;
	}
	.ext {
		display: inline-block;
		text-decoration: none;
		color: var(--tx-2);
		font-size: 0.95rem;
		padding: 0.15rem 0.1rem;
		border-bottom: 2px solid transparent;
		transition:
			color 0.2s ease,
			border-color 0.2s ease;
	}
	.ext:hover {
		color: var(--tx);
		border-bottom-color: var(--sun);
	}
	.ext .arrow {
		font-size: 0.8em;
		color: var(--sun);
	}
	.icons {
		display: flex;
		align-items: center;
		gap: 0.15rem;
	}
	.icon {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0.45rem;
		border-radius: 50%;
		color: var(--tx-2);
		transition:
			color 0.2s ease,
			background 0.2s ease;
	}
	.icon.gh:hover {
		color: var(--lav);
		background: color-mix(in srgb, var(--lav) 14%, transparent);
	}
	.icon.yt:hover {
		color: var(--coral);
		background: color-mix(in srgb, var(--coral) 14%, transparent);
	}
	.icon.ig:hover {
		color: var(--coral);
		background: color-mix(in srgb, var(--coral) 14%, transparent);
	}
	.icon.rss:hover {
		color: var(--sun);
		background: color-mix(in srgb, var(--sun) 14%, transparent);
	}

	@media (max-width: 640px) {
		nav {
			gap: 1rem;
		}
		.links {
			gap: 0.8rem;
		}
		/* 小屏隐藏导航里的英文副词，避免换行 */
		.links .en-word {
			display: none;
		}
	}
</style>
