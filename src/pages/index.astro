---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import CardNote from '../components/CardNote.astro';
import FilterBar from '../components/FilterBar.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import HiddenText from '../components/HiddenText.astro';
import Verse from '../components/Verse.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { tagColorIndex } from '../lib/tag-color';

const posts = await getCollection('blog');
const cards = (await getCollection('cards')).filter((c) => c.data.section === 'notes');

// 长文和短札按日期混排在同一条时间流里
type Item =
	| { kind: 'post'; entry: CollectionEntry<'blog'> }
	| { kind: 'card'; entry: CollectionEntry<'cards'> };
const items: Item[] = [
	...posts.map((entry): Item => ({ kind: 'post', entry })),
	...cards.map((entry): Item => ({ kind: 'card', entry })),
].sort((a, b) => b.entry.data.pubDate.valueOf() - a.entry.data.pubDate.valueOf());

// 列表里只显示到月份，完整日期在文章页/短札展开后
const ym = (d: Date) => `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}`;

// `foo.en` 是 `foo` 的英文版：列表里两版都渲染，按当前语言只显示其一
const postMeta = (id: string) => {
	const isEn = id.endsWith('.en');
	const base = isEn ? id.slice(0, -3) : id;
	return { base, href: isEn ? `/blog/${base}/en/` : `/blog/${id}/` };
};

// 筛选条数据：出现过的所有标签（字母序）+ 年份（新到旧），长文和短札都算
const allTags = [...new Set(items.flatMap(({ entry }) => entry.data.tags))].sort((a, b) =>
	a.localeCompare(b, 'zh'),
);
const allYears = [...new Set(items.map(({ entry }) => entry.data.pubDate.getFullYear()))].sort(
	(a, b) => b - a,
);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1 class="verse"><Verse lines={["Thou lovest, but ne'er knew love's sad satiety."]} /></h1>
			</section>

			<FilterBar tags={allTags} years={allYears} />

			<section class="posts">
				<ul class="post-list">
					{
						items.map((item, i) => {
							if (item.kind === 'card') {
								return <CardNote card={item.entry} index={i} variant="flow" />;
							}
							const post = item.entry;
							const { base, href } = postMeta(post.id);
							return (
								<li
									class={`c${i % 5}`}
									data-lang={post.data.lang}
									data-base={base}
									data-tags={post.data.tags.join('|')}
									data-year={post.data.pubDate.getFullYear()}
								>
									<a href={href}>
										<span class="date">
											<time datetime={post.data.pubDate.toISOString()}>{ym(post.data.pubDate)}</time>
										</span>
										<span class="body">
											<span class="post-title">{post.data.title}</span>
											{post.data.tags.length > 0 && (
												<span class="tags">
													{post.data.tags.map((tag) => (
														<span class:list={['tag', `c${tagColorIndex(tag)}`]}>#{tag}</span>
													))}
												</span>
											)}
										</span>
									</a>
								</li>
							);
						})
					}
				</ul>
			</section>
		</main>
		<Footer />
		<HiddenText />

		<script>
			// 同一篇文章的中英两版只显示当前语言那版；没有翻译的文章始终显示
			const applyLang = () => {
				const lang = document.documentElement.dataset.lang || 'zh';
				const items = [...document.querySelectorAll<HTMLLIElement>('.post-list li')];
				const groups = new Map<string, HTMLLIElement[]>();
				items.forEach((li) => {
					const base = li.dataset.base || '';
					groups.set(base, [...(groups.get(base) || []), li]);
				});
				groups.forEach((group) => {
					if (group.length === 1) {
						group[0].style.display = '';
						return;
					}
					let shown = false;
					group.forEach((li) => {
						const match = li.dataset.lang === lang;
						li.style.display = match ? '' : 'none';
						shown ||= match;
					});
					if (!shown) group[0].style.display = '';
				});
			};
			applyLang();
			document.addEventListener('langchange', applyLang);
		</script>
	</body>
</html>

<style>
	/* 引言诗句上移收紧；字体样式在 global.css 的 .hero .verse 统一定义 */
	.hero {
		margin: 0.8rem 0 2.2rem;
	}

	.post-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.post-list li {
		margin: 0;
	}
	.post-list li.c0 {
		--c: var(--coral);
	}
	.post-list li.c1 {
		--c: var(--mint);
	}
	.post-list li.c2 {
		--c: var(--lav);
	}
	.post-list li.c3 {
		--c: var(--sun);
	}
	.post-list li.c4 {
		--c: var(--sky);
	}
	.post-list a {
		display: grid;
		grid-template-columns: 4.6rem 1fr;
		gap: 1.2rem;
		align-items: baseline;
		padding: 1.05rem 0.4rem;
		text-decoration: none;
		border-radius: 10px;
		border-bottom: 1px solid var(--line);
		transition: background 0.2s ease;
	}
	.post-list li:last-child a {
		border-bottom: none;
	}
	.post-list a:hover {
		background: color-mix(in srgb, var(--c) 7%, transparent);
	}
	.date {
		font-family: var(--font-mono);
		font-size: 0.82rem;
		color: var(--tx-2);
		white-space: nowrap;
	}
	.body {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 0.3rem 0.7rem;
	}
	.post-title {
		font-weight: 600;
		font-size: 1.08rem;
		color: var(--tx);
		background-image: linear-gradient(var(--c), var(--c));
		background-repeat: no-repeat;
		background-size: 0% 2px;
		background-position: 0 100%;
		padding-bottom: 2px;
		transition: background-size 0.25s ease;
	}
	.post-list a:hover .post-title {
		background-size: 100% 2px;
	}
	.tags {
		display: inline-flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}
	.tag {
		font-family: var(--font-mono);
		font-size: 0.78rem;
		color: var(--c);
	}

	@media (max-width: 560px) {
		.post-list a {
			grid-template-columns: 1fr;
			gap: 0.25rem;
		}
	}
</style>
