---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// `foo.en` 是 `foo` 的英文版：列表里两版都渲染，按当前语言只显示其一
const postMeta = (id: string) => {
	const isEn = id.endsWith('.en');
	const base = isEn ? id.slice(0, -3) : id;
	return { base, href: isEn ? `/blog/${base}/en/` : `/blog/${id}/` };
};
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1 class="only-zh">你好，我是 Agnes <span class="wave">👋</span></h1>
				<h1 class="only-en">Hi, I'm Agnes <span class="wave">👋</span></h1>
				<p class="intro only-zh">
					在这里记<mark class="m-coral">笔记</mark>、写<mark class="m-mint">故事</mark
					>，也放一些<mark class="m-lav">照片</mark>。
				</p>
				<p class="intro only-en">
					I keep <mark class="m-coral">notes</mark>, tell <mark class="m-mint">stories</mark>, and
					take <mark class="m-lav">photos</mark> here.
				</p>
			</section>

			<section class="posts">
				<ul class="post-list">
					{
						posts.map((post, i) => {
							const { base, href } = postMeta(post.id);
							return (
								<li class={`c${i % 5}`} data-lang={post.data.lang} data-base={base}>
									<a href={href}>
										<span class="date">
											<FormattedDate date={post.data.pubDate} />
										</span>
										<span class="body">
											<span class="post-title">{post.data.title}</span>
											{post.data.tags.length > 0 && (
												<span class="tags">
													{post.data.tags.map((tag) => (
														<span class="tag">#{tag}</span>
													))}
												</span>
											)}
										</span>
									</a>
								</li>
							);
						})
					}
				</ul>
			</section>
		</main>
		<Footer />

		<script>
			// 同一篇文章的中英两版只显示当前语言那版；没有翻译的文章始终显示
			const applyLang = () => {
				const lang = document.documentElement.dataset.lang || 'zh';
				const items = [...document.querySelectorAll<HTMLLIElement>('.post-list li')];
				const groups = new Map<string, HTMLLIElement[]>();
				items.forEach((li) => {
					const base = li.dataset.base || '';
					groups.set(base, [...(groups.get(base) || []), li]);
				});
				groups.forEach((group) => {
					if (group.length === 1) {
						group[0].style.display = '';
						return;
					}
					let shown = false;
					group.forEach((li) => {
						const match = li.dataset.lang === lang;
						li.style.display = match ? '' : 'none';
						shown ||= match;
					});
					if (!shown) group[0].style.display = '';
				});
			};
			applyLang();
			document.addEventListener('langchange', applyLang);
		</script>
	</body>
</html>

<style>
	.hero {
		margin: 2.5rem 0 3rem;
	}
	.hero h1 {
		font-size: 2rem;
		letter-spacing: -0.02em;
		margin: 0 0 0.8rem;
	}
	.wave {
		display: inline-block;
	}
	.intro {
		font-size: 1.05rem;
		color: var(--tx);
		line-height: 2;
		margin: 0;
	}
	mark {
		background: none;
		color: inherit;
		padding: 0 0.1em;
		background-image: linear-gradient(transparent 62%, var(--mark) 62%);
	}
	.m-coral {
		--mark: color-mix(in srgb, var(--coral) 30%, transparent);
	}
	.m-mint {
		--mark: color-mix(in srgb, var(--mint) 32%, transparent);
	}
	.m-lav {
		--mark: color-mix(in srgb, var(--lav) 30%, transparent);
	}

	.post-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.post-list li {
		margin: 0;
	}
	.post-list li.c0 {
		--c: var(--coral);
	}
	.post-list li.c1 {
		--c: var(--mint);
	}
	.post-list li.c2 {
		--c: var(--lav);
	}
	.post-list li.c3 {
		--c: var(--sun);
	}
	.post-list li.c4 {
		--c: var(--sky);
	}
	.post-list a {
		display: grid;
		grid-template-columns: 6.5rem 1fr;
		gap: 1.2rem;
		align-items: baseline;
		padding: 1.05rem 0.4rem;
		text-decoration: none;
		border-radius: 10px;
		border-bottom: 1px solid var(--line);
		transition: background 0.2s ease;
	}
	.post-list li:last-child a {
		border-bottom: none;
	}
	.post-list a:hover {
		background: color-mix(in srgb, var(--c) 7%, transparent);
	}
	.date {
		font-family: var(--font-mono);
		font-size: 0.82rem;
		color: var(--tx-2);
		white-space: nowrap;
	}
	.body {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 0.3rem 0.7rem;
	}
	.post-title {
		font-weight: 600;
		font-size: 1.08rem;
		color: var(--tx);
		background-image: linear-gradient(var(--c), var(--c));
		background-repeat: no-repeat;
		background-size: 0% 2px;
		background-position: 0 100%;
		padding-bottom: 2px;
		transition: background-size 0.25s ease;
	}
	.post-list a:hover .post-title {
		background-size: 100% 2px;
	}
	.tags {
		display: inline-flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}
	.tag {
		font-family: var(--font-mono);
		font-size: 0.78rem;
		color: var(--c);
	}

	@media (max-width: 560px) {
		.post-list a {
			grid-template-columns: 1fr;
			gap: 0.25rem;
		}
	}
</style>
