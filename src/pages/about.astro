---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About · ${SITE_TITLE}`} description="The world is not beautiful, therefore it is." />
	</head>
	<body>
		<Header />
		<main>
			<p class="motto">The world is not beautiful, <em>therefore</em> it is.</p>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.motto {
		margin: 0;
		padding-bottom: 12vh; /* 视觉重心略高于几何中心 */
		font-size: clamp(1.25rem, 3.2vw, 1.7rem);
		line-height: 1.9;
		letter-spacing: 0.01em;
		text-align: center;
		text-wrap: balance;
		color: var(--tx);
	}
	.motto em {
		font-style: italic;
		color: var(--coral);
	}
</style>
