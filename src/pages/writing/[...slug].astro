---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const pieces = await getCollection('writing');
	return pieces.map((piece) => ({
		params: { slug: piece.id },
		props: piece,
	}));
}
type Props = CollectionEntry<'writing'>;

const piece = Astro.props;
const { Content, headings } = await render(piece);

// 与笔记页同款三栏：右侧文内目录（h2–h4），左侧按年份分组的作品时间轴
const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 4 && h.text.trim() !== '');

const timeline = (await getCollection('writing'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.map((p) => ({
		id: p.id,
		base: p.id,
		href: `/writing/${p.id}/`,
		title: p.data.title,
		lang: p.data.lang,
		year: p.data.pubDate.getFullYear(),
		mmdd: '', // 夜莺颂只按年份分组,不显示月/日
	}));
---

<BlogPost
	{...piece.data}
	backHref="/writing/"
	backLabelZh="回到夜莺颂"
	backLabelEn="All fiction"
	dateYearOnly={true}
	headings={tocHeadings}
	timeline={timeline}
	currentId={piece.id}
>
	<Content />
</BlogPost>
