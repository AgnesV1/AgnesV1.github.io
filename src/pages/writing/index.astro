---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import CardNote from '../../components/CardNote.astro';
import FilterBar from '../../components/FilterBar.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import HiddenText from '../../components/HiddenText.astro';
import Verse from '../../components/Verse.astro';
import { SITE_TITLE } from '../../consts';
import { excerptOf } from '../../lib/excerpt';
import { tagColorIndex } from '../../lib/tag-color';

const pieces = (await getCollection('writing')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// 短札（fiction 归属）：在长篇下方铺成便签墙
const cards = (await getCollection('cards'))
	.filter((c) => c.data.section === 'fiction')
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// 筛选条数据：标签（字母序）+ 年份（新到旧），长篇和短札都算；不够多时筛选条自动不渲染
const all = [...pieces, ...cards];
const allTags = [...new Set(all.flatMap((p) => p.data.tags))].sort((a, b) => a.localeCompare(b, 'zh'));
const allYears = [...new Set(all.map((p) => p.data.pubDate.getFullYear()))].sort((a, b) => b - a);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`夜莺颂 Fiction · ${SITE_TITLE}`} description="Was it a vision, or a waking dream?" />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1 class="verse"><Verse lines={["Was it a vision, or a waking dream?"]} /></h1>
			</section>

			<FilterBar tags={allTags} years={allYears} />

			<section class="posts">
				<details class="zone" open>
					<summary>
						<span class="only-zh">长篇</span><span class="only-en">Long-form</span>
						<span class="zone-count">· {pieces.length}</span>
					</summary>
				{
					pieces.length === 0 ? (
						<p class="empty">
							<span class="only-zh">还没有作品，快写第一篇吧。</span>
							<span class="only-en">Nothing here yet — the first story is on its way.</span>
						</p>
					) : (
						<ul class="post-list">
							{pieces.map((piece, i) => (
								<li
									class={`c${i % 5}`}
									data-tags={piece.data.tags.join('|')}
									data-year={piece.data.pubDate.getFullYear()}
								>
									<a href={`/writing/${piece.id}/`}>
										<span class="body">
											<span class="post-title">{piece.data.title}</span>
											<span class="excerpt">{excerptOf(piece.body, 18)}</span>
											{piece.data.tags.length > 0 && (
												<span class="tags">
													{piece.data.tags.map((tag) => (
														<span class:list={['tag', `c${tagColorIndex(tag)}`]}>#{tag}</span>
													))}
												</span>
											)}
										</span>
									</a>
								</li>
							))}
						</ul>
					)
				}
				</details>

				{
					cards.length > 0 && (
						<div class="zone cards-zone">
							<p class="zone-head">
								<span class="only-zh">短札</span>
								<span class="only-en">Cards</span>
								<span class="zone-count">· {cards.length}</span>
							</p>
							<ul class="cards-wall">
								{cards.map((card, i) => (
									<CardNote card={card} index={i} variant="wall" />
								))}
							</ul>
						</div>
					)
				}
			</section>
		</main>
		<Footer />
		<HiddenText />

		<script>
			// 短札的中英两版只显示当前语言那版（长篇不做双语配对，不受影响）
			const applyCardLang = () => {
				const lang = document.documentElement.dataset.lang || 'zh';
				const items = [...document.querySelectorAll<HTMLLIElement>('.cards-wall li')];
				const groups = new Map<string, HTMLLIElement[]>();
				items.forEach((li) => {
					const base = li.dataset.base || '';
					groups.set(base, [...(groups.get(base) || []), li]);
				});
				groups.forEach((group) => {
					if (group.length === 1) {
						group[0].style.display = '';
						return;
					}
					let shown = false;
					group.forEach((li) => {
						const match = li.dataset.lang === lang;
						li.style.display = match ? '' : 'none';
						shown ||= match;
					});
					if (!shown) group[0].style.display = '';
				});
			};
			applyCardLang();
			document.addEventListener('langchange', applyCardLang);
		</script>
	</body>
</html>

<style>
	/* 引言诗句上移收紧；字体样式在 global.css 的 .hero .verse 统一定义 */
	.hero {
		margin: 0.8rem 0 2.2rem;
	}
	.empty {
		color: var(--tx-2);
		font-size: 0.95rem;
	}

	/* 分区标题：长篇是可折叠的 summary，短札是普通标题，两者视觉一致 */
	.zone summary,
	.zone-head {
		font-family: var(--font-mono);
		font-size: 0.85rem;
		color: var(--tx-2);
		margin: 0;
		user-select: none;
	}
	.zone summary {
		cursor: pointer;
		transition: color 0.2s ease;
	}
	.zone summary:hover {
		color: var(--mint);
	}
	.zone-count {
		color: var(--mint);
	}
	.cards-zone {
		margin-top: 2.8rem;
	}

	/* 便签墙：flex 错落——每张宽度随内容长短，一行自动挤放，展开的卡占满整行 */
	.cards-wall {
		list-style: none;
		margin: 1rem 0 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		align-items: flex-start;
		gap: 0.85rem;
	}

	.post-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.post-list li {
		margin: 0;
	}
	.post-list li.c0 {
		--c: var(--coral);
	}
	.post-list li.c1 {
		--c: var(--mint);
	}
	.post-list li.c2 {
		--c: var(--lav);
	}
	.post-list li.c3 {
		--c: var(--sun);
	}
	.post-list li.c4 {
		--c: var(--sky);
	}
	/* 长篇条目不显示日期（完整日期在文章页里），标题 + 首句摘录 + tags 一行流 */
	.post-list a {
		display: block;
		padding: 1.05rem 0.4rem;
		text-decoration: none;
		border-radius: 10px;
		border-bottom: 1px solid var(--line);
		transition: background 0.2s ease;
	}
	.post-list li:last-child a {
		border-bottom: none;
	}
	.post-list a:hover {
		background: color-mix(in srgb, var(--c) 7%, transparent);
	}
	.body {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 0.3rem 0.7rem;
	}
	.excerpt {
		color: var(--tx-2);
		font-size: 0.92rem;
	}
	.post-title {
		font-weight: 600;
		font-size: 1.08rem;
		color: var(--tx);
		background-image: linear-gradient(var(--c), var(--c));
		background-repeat: no-repeat;
		background-size: 0% 2px;
		background-position: 0 100%;
		padding-bottom: 2px;
		transition: background-size 0.25s ease;
	}
	.post-list a:hover .post-title {
		background-size: 100% 2px;
	}
	.tags {
		display: inline-flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}
	.tag {
		font-family: var(--font-mono);
		font-size: 0.78rem;
		color: var(--c);
	}

	@media (max-width: 560px) {
		.post-list a {
			grid-template-columns: 1fr;
			gap: 0.25rem;
		}
	}
</style>
